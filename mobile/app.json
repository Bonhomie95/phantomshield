{
  "expo": {
    "name": "PhantomShield",
    "slug": "phantomshield",
    "scheme": "phantomshield",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C12"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.bonhomie95.phantomshield",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "deploymentTarget": "15.1",
      "infoPlist": {
        "NSCameraUsageDescription": "PhantomShield captures intruder photos when unauthorized access is attempted. This is disclosed to you during setup and requires your explicit opt-in.",
        "NSFaceIDUsageDescription": "PhantomShield uses Face ID to verify your identity every time you open the app.",
        "NSLocationWhenInUseUsageDescription": "PhantomShield can log the location of your device during unauthorized access attempts, if you enable this feature.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.119391523094-10al3p2cdaid85r958vp8033en9u0g7i"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundColor": "#080C12"
      },
      "package": "dev.bonhomie95.phantomshield",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-apple-authentication",
      "expo-task-manager",
      "expo-background-task",
      "expo-sensors",
      "expo-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PhantomShield logs your device's location during an unauthorized-access or anti-theft alarm event, if you enable it."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PhantomShield uses the front camera to silently capture intruder photos when an incorrect PIN is entered. This feature is opt-in and fully disclosed during setup."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#00D4FF",
          "sounds": []
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "59774380-33f7-414a-ac86-52528266a0b9"
      }
    },
    "owner": "bonhomie95"
  }
}
