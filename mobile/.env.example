# PhantomShield mobile — copy to .env and fill in.
#
# Backend base URL. MUST include the /api prefix and the backend port (3002).
#   LAN dev:     http://<your-computer-ip>:3002/api
#   Production:  https://api.phantomshield.app/api
EXPO_PUBLIC_API_URL=http://192.168.100.44:3002/api

# Google OAuth client IDs (https://console.cloud.google.com -> Credentials).
# Create a Web, an iOS, and an Android OAuth client ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com

# RevenueCat (in-app purchases) — optional; billing no-ops without these
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# PostHog product analytics — optional
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AdMob interstitial ad units — optional; Guard Mode ads no-op without these.
# Requires `npx expo install react-native-google-mobile-ads` + config plugin.
# In development, Google's test ad unit is used automatically if left blank.
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
